PORT=3000
HOST_PORT=3000

# Development tunnel with Docker:
# npm run docker:dev
# Use the generated https://*.trycloudflare.com/mcp URL in ChatGPT.
# The MCP server path defaults to /mcp.

# Production:
# Deploy the Docker container behind HTTPS, or use a named Cloudflare Tunnel
# token with: npm run docker:prod
# CLOUDFLARED_TUNNEL_TOKEN=your_named_tunnel_token
