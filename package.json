{
  "name": "exchange-rate-mcp",
  "version": "1.0.0",
  "description": "MCP server for ExchangeRate.dev currency conversion.",
  "main": "src/server.ts",
  "scripts": {
    "start": "node --env-file=.env --import tsx src/server.ts",
    "docker:build": "docker build -t exchange-rate-mcp .",
    "docker": "docker compose up --build",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:unit",
    "test:unit": "node --import tsx --test test/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "tsx": "^4.22.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
